{
  "name": "transducer-ts",
  "version": "0.1.0",
  "description": "Type-safe Clojure-style transducers for TypeScript. Composable algorithmic transformations with full type inference.",
  "type": "module",
  "packageManager": "yarn@4.13.0",
  "license": "Unlicense",
  "author": "transducer-ts contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/transducer-ts/transducer-ts.git"
  },
  "keywords": [
    "transducer",
    "transducers",
    "functional",
    "composition",
    "typescript",
    "clojure"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./map": {
      "types": "./dist/map.d.ts",
      "import": "./dist/map.js"
    },
    "./filter": {
      "types": "./dist/filter.d.ts",
      "import": "./dist/filter.js"
    },
    "./take": {
      "types": "./dist/take.d.ts",
      "import": "./dist/take.js"
    },
    "./drop": {
      "types": "./dist/drop.d.ts",
      "import": "./dist/drop.js"
    },
    "./pipe": {
      "types": "./dist/pipe.d.ts",
      "import": "./dist/pipe.js"
    },
    "./transduce": {
      "types": "./dist/transduce.d.ts",
      "import": "./dist/transduce.js"
    },
    "./into": {
      "types": "./dist/into.d.ts",
      "import": "./dist/into.js"
    },
    "./sequence": {
      "types": "./dist/sequence.d.ts",
      "import": "./dist/sequence.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --build && tsc --project tsconfig.test.json --noEmit",
    "lint": "oxlint",
    "fmt": "oxfmt --write src",
    "fmt:check": "oxfmt --check src",
    "check": "yarn typecheck && yarn lint && yarn fmt:check",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "prepublishOnly": "yarn check && yarn test && yarn build && yarn pack -o /tmp/transducer-ts-attw.tgz && npx @arethetypeswrong/cli /tmp/transducer-ts-attw.tgz --ignore-rules cjs-resolves-to-esm no-resolution && npx publint",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "oxfmt --write",
      "oxlint"
    ]
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "rambda": "^11.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "rambda": "^11.1.0"
  },
  "peerDependenciesMeta": {
    "rambda": {
      "optional": true
    }
  }
}
