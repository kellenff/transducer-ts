{
  "name": "@fromo/transducer-ts",
  "version": "0.1.0",
  "description": "Type-safe Clojure-style transducers for TypeScript. Composable algorithmic transformations with full type inference.",
  "type": "module",
  "packageManager": "yarn@4.13.0",
  "license": "Unlicense",
  "author": "Kellen Frodelius-Fujimoto",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/transducer-ts/transducer-ts.git"
  },
  "keywords": [
    "transducer",
    "transducers",
    "functional",
    "composition",
    "typescript",
    "clojure"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "llms.txt"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./map": {
      "types": "./dist/map/index.d.ts",
      "import": "./dist/map/index.js"
    },
    "./filter": {
      "types": "./dist/filter/index.d.ts",
      "import": "./dist/filter/index.js"
    },
    "./filterGuard": {
      "types": "./dist/filterGuard/index.d.ts",
      "import": "./dist/filterGuard/index.js"
    },
    "./take": {
      "types": "./dist/take/index.d.ts",
      "import": "./dist/take/index.js"
    },
    "./drop": {
      "types": "./dist/drop/index.d.ts",
      "import": "./dist/drop/index.js"
    },
    "./pipe": {
      "types": "./dist/pipe/index.d.ts",
      "import": "./dist/pipe/index.js"
    },
    "./transduce": {
      "types": "./dist/transduce/index.d.ts",
      "import": "./dist/transduce/index.js"
    },
    "./into": {
      "types": "./dist/into/index.d.ts",
      "import": "./dist/into/index.js"
    },
    "./sequence": {
      "types": "./dist/sequence/index.d.ts",
      "import": "./dist/sequence/index.js"
    },
    "./toFn": {
      "types": "./dist/toFn/index.d.ts",
      "import": "./dist/toFn/index.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc --build",
    "typecheck": "tsc --build && tsc --project tsconfig.test.json --noEmit",
    "lint": "oxlint",
    "fmt": "oxfmt --write src",
    "fmt:check": "oxfmt --check src",
    "check": "yarn typecheck && yarn lint && yarn fmt:check",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "prepublishOnly": "yarn check && yarn test && yarn build && yarn pack -o /tmp/transducer-ts-attw.tgz && yarn dlx @arethetypeswrong/cli /tmp/transducer-ts-attw.tgz --ignore-rules cjs-resolves-to-esm no-resolution && yarn dlx publint",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "oxfmt --write",
      "oxlint",
      "vitest related --run"
    ]
  },
  "devDependencies": {
    "@types/lodash": "^4.17.24",
    "@types/ramda": "^0.31.1",
    "@types/underscore": "^1.13.0",
    "@vitest/coverage-v8": "^4.1.0",
    "fp-ts": "^2.16.11",
    "husky": "^9.1.7",
    "itertools": "^2.6.0",
    "lint-staged": "^16.4.0",
    "lodash": "^4.17.23",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "rambda": "^11.1.0",
    "ramda": "^0.32.0",
    "remeda": "^2.33.6",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "underscore": "^1.13.8",
    "vitest": "^4.1.0"
  }
}
